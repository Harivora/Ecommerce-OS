# ============================================================
# Secrets — NEVER commit these
# ============================================================
.env
.env.*
!.env.example
!.env.production.example
**/.env
**/.env.local
**/.env.*.local

# Terraform secrets + state
deploy/terraform/terraform.tfvars
*.tfvars
!*.tfvars.example
*.tfstate
*.tfstate.*
**/.terraform/
.terraform.lock.hcl

# SSH / private keys
*.pem
*_key
*_key.pub
id_rsa*
id_ed25519*

# ============================================================
# Databases (contain real customer PII — do not push)
# ============================================================
*.db
*.sqlite
*.sqlite3

