# ── Application ──────────────────────────────────────────────
APP_NAME="AI Commerce OS"
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
# Comma-separated list of allowed CORS origins (the Next.js frontend)
CORS_ORIGINS=http://localhost:3000

# ── Database (PostgreSQL) ────────────────────────────────────
# Async driver URL used by the API + workers
DATABASE_URL=postgresql+asyncpg://commerce:commerce@postgres:5432/commerce
# Sync URL used by Alembic migrations
DATABASE_URL_SYNC=postgresql+psycopg://commerce:commerce@postgres:5432/commerce

# ── Redis (cache + Celery broker/backend) ────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Security ─────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
# Fernet key for encrypting integration credentials at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-generate-a-fernet-key

# ── First super-admin (seeded on startup if not present) ─────
SUPERADMIN_EMAIL=admin@commerceos.ai
SUPERADMIN_PASSWORD=change-me-strong-password
SUPERADMIN_NAME="Platform Owner"

# ── Anthropic (Claude AI analyst) ────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
AI_MAX_TOKENS=1024

# ── Sync scheduling ──────────────────────────────────────────
SYNC_INTERVAL_MINUTES=60

# ── SMTP (optional; password-reset emails). If blank, reset
#    tokens are returned in the API response / logs instead. ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@commerceos.ai
