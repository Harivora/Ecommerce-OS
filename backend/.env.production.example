# =============================================================
# AI Commerce OS — PRODUCTION environment template (AWS)
# -------------------------------------------------------------
# Copy the NON-SECRET values into your ECS task definition env.
# Put every value marked  >>> SECRET <<<  in AWS Secrets Manager
# and inject it via the task definition's `secrets:` block — NEVER
# commit real secrets to git. This file holds placeholders only.
# =============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME="AI Commerce OS"
ENVIRONMENT=production
API_V1_PREFIX=/api/v1
# Lock this to your real frontend origin(s), comma-separated.
CORS_ORIGINS=https://app.yourdomain.com

# ── Database (RDS PostgreSQL) ────────────────────────────────
# Use the RDS endpoint. The password portion comes from Secrets
# Manager — build the full URL in the task def from the secret,
# or store the whole URL as a secret. Keep RDS in a PRIVATE subnet.
# Async driver URL used by the API + workers:
DATABASE_URL=postgresql+asyncpg://commerce:CHANGE_ME@your-rds-endpoint.rds.amazonaws.com:5432/commerce   # >>> SECRET <<<
# Sync URL used by Alembic migrations:
DATABASE_URL_SYNC=postgresql+psycopg://commerce:CHANGE_ME@your-rds-endpoint.rds.amazonaws.com:5432/commerce   # >>> SECRET <<<

# ── Redis (ElastiCache) — Celery broker/backend + cache ──────
# Use the ElastiCache primary endpoint. Keep it in a PRIVATE subnet.
# If you enable in-transit encryption, use the rediss:// scheme.
REDIS_URL=redis://your-elasticache-endpoint:6379/0
CELERY_BROKER_URL=redis://your-elasticache-endpoint:6379/1
CELERY_RESULT_BACKEND=redis://your-elasticache-endpoint:6379/2
# Production uses a REAL broker — do NOT run tasks inline.
CELERY_TASK_ALWAYS_EAGER=false

# ── Security ─────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME   # >>> SECRET <<<
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
# MASTER KEY for all stored integration credentials. If this leaks,
# every customer's API keys can be decrypted. Store ONLY in Secrets
# Manager; back it up; rotating it requires re-encrypting all creds.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME   # >>> SECRET <<<

# ── First super-admin (seeded on startup if not present) ─────
SUPERADMIN_EMAIL=you@yourdomain.com
SUPERADMIN_PASSWORD=CHANGE_ME_STRONG   # >>> SECRET <<<
SUPERADMIN_NAME="Platform Owner"

# ── Anthropic (Claude AI analyst) ────────────────────────────
# Optional global fallback key. Per-org keys entered in the UI take
# precedence. If you set this, store it in Secrets Manager.
ANTHROPIC_API_KEY=   # >>> SECRET (if used) <<<
ANTHROPIC_MODEL=claude-opus-4-8
AI_MAX_TOKENS=1024

# ── Real-time sync (the whole point of going live) ───────────
# Public HTTPS base URL where Shopify can reach this API. Setting
# this makes the connect flow auto-register Shopify webhooks, so
# orders/refunds/products land within SECONDS.
PUBLIC_WEBHOOK_BASE_URL=https://api.yourdomain.com
# Celery beat runs a periodic safety-net resync at this interval
# (webhooks handle the real-time path; this catches anything missed).
SYNC_INTERVAL_MINUTES=60
# Turn OFF the in-process polling thread — Celery beat handles
# scheduling in production. (Only used in local/no-broker mode.)
LOCAL_SCHEDULER_ENABLED=false

# ── SMTP (optional; password-reset emails) ───────────────────
# If blank, reset tokens are returned in the API response / logs.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=   # >>> SECRET (if used) <<<
SMTP_FROM=no-reply@yourdomain.com
